---
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import BaseHead from "../components/BaseHead.astro";
import RPFrame from "./RPFrame.astro";

type Props = {
	post: CollectionEntry<"blog">;
};

const { post } = Astro.props;

const {
	title,
	description,
	pubDate,
	updatedDate,
	heroImage,
	author,
	tags = [],
} = post.data;
---

<html lang="es">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			:global(.rp-frameContent.rp-postLayout) {
				display: flex;
				flex-direction: column;
				flex: 1;
				min-width: 0;
				min-height: 0;
				height: 100%;
				overflow-y: auto;
				padding: 1.2rem 1.75rem 1.25rem;
			}

			.rp-post {
				width: 100%;
				max-width: none;
			}

			.rp-post__header,
			.rp-post__lead,
			.rp-post__content,
			.rp-post__nav {
				width: min(760px, 100%);
			}

			.rp-post__hero {
				width: min(980px, 100%);
			}

			.rp-post__crumb {
				margin: 0 0 0.7rem 0;
				color: rgb(var(--gray));
				font-size: 0.8rem;
				letter-spacing: 0.02em;
			}

			.rp-post__crumb a {
				color: rgb(var(--gray));
				text-decoration: none;
			}

			.rp-post__crumb a:hover {
				color: rgb(var(--gray-dark));
				text-decoration: underline;
			}

			.rp-post__header {
				padding-bottom: 0.9rem;
				border-bottom: 1px solid rgba(var(--rp-border), 0.12);
			}

			.rp-post__title {
				margin: 0;
				font-size: clamp(1.7rem, 2.4vw, 2.35rem);
				line-height: 1.06;
				letter-spacing: -0.02em;
			}

			.rp-post__meta {
				margin-top: 0.55rem;
				display: flex;
				flex-wrap: wrap;
				gap: 0.3rem 0.55rem;
				color: rgb(var(--gray));
				font-size: 0.8rem;
				line-height: 1.45;
			}

			.rp-post__metaPrimary {
				color: rgb(var(--gray-dark));
			}

			.rp-post__author {
				color: rgb(var(--gray-dark));
				font-weight: 600;
			}

			.rp-post__updated {
				color: rgb(var(--gray));
			}

			.rp-post__tags {
				display: flex;
				flex-wrap: wrap;
				gap: 0.45rem;
				margin-top: 0.55rem;
			}

			.rp-post__tag {
				display: inline-flex;
				padding: 0.25rem 0.58rem;
				border-radius: 999px;
				border: 1px solid rgba(255, 255, 255, 0.1);
				background: rgba(255, 255, 255, 0.03);
				color: rgb(var(--gray-dark));
				font-size: 0.76rem;
				text-decoration: none;
			}

			.rp-post__tag:hover {
				border-color: rgba(255, 255, 255, 0.16);
			}

			.rp-post__lead {
				margin: 0.9rem 0 0.9rem 0;
				color: rgb(var(--gray-dark));
				font-size: 0.98rem;
				line-height: 1.7;
				max-width: 62ch;
			}

			.rp-post__hero {
				margin: 0 0 1rem 0;
				overflow: hidden;
				border-radius: 10px;
				border: 1px solid rgba(var(--rp-border), 0.1);
				background: rgba(255, 255, 255, 0.03);
			}

			.rp-post__hero img {
				width: 100%;
				height: 280px;
				object-fit: cover;
				object-position: center;
				display: block;
				border: 0;
				border-radius: 0;
			}

			.rp-post__content {
				color: rgb(var(--gray-dark));
				max-width: 66ch;
			}

			.rp-post__content :global(h2) {
				margin-top: 1.55rem;
				margin-bottom: 0.5rem;
				font-size: 1.3rem;
				line-height: 1.2;
			}

			.rp-post__content :global(h3) {
				margin-top: 1.35rem;
				margin-bottom: 0.5rem;
				font-size: 1.12rem;
				line-height: 1.25;
			}

			.rp-post__content :global(p),
			.rp-post__content :global(ul),
			.rp-post__content :global(ol) {
				color: rgb(var(--gray-dark));
				font-size: 0.95rem;
				line-height: 1.78;
			}

			.rp-post__content :global(ul),
			.rp-post__content :global(ol) {
				padding-left: 1.35rem;
			}

			.rp-post__content :global(li) {
				margin-bottom: 0.4rem;
			}

			.rp-post__content :global(blockquote) {
				margin: 1.3rem 0;
				padding-left: 1rem;
				border-left: 3px solid var(--accent);
				color: rgb(var(--gray));
				font-size: 0.98rem;
			}

			.rp-post__content :global(pre) {
				margin: 1.2rem 0;
			}

			.rp-post__nav {
				margin-top: 2rem;
				padding-top: 1rem;
				border-top: 1px solid rgba(var(--rp-border), 0.12);
				display: flex;
				justify-content: flex-start;
			}

			.rp-post__back {
				color: rgb(var(--gray));
				text-decoration: none;
				font-size: 0.9rem;
			}

			.rp-post__back:hover {
				color: rgb(var(--gray-dark));
				text-decoration: underline;
			}

			@media (max-width: 980px) {
				:global(.rp-frameContent.rp-postLayout) {
					overflow: visible;
					min-height: auto;
					height: auto;
				}

				.rp-post__header,
				.rp-post__lead,
				.rp-post__content,
				.rp-post__nav,
				.rp-post__hero {
					width: 100%;
				}
			}

			@media (max-width: 720px) {
				:global(.rp-frameContent.rp-postLayout) {
					padding: 1.1rem 1rem 1.1rem;
				}

				.rp-post__title {
					font-size: 1.9rem;
				}

				.rp-post__hero img {
					height: 220px;
				}
			}
		</style>
	</head>

	<body>
		<RPFrame frameClass="rp-frameBody" contentClass="rp-frameContent rp-postLayout">
			<article class="rp-post">
				<p class="rp-post__crumb">
					<a href="/blog">Blog</a>{tags.length > 0 ? ` / ${tags[0]}` : ""}
				</p>

				<header class="rp-post__header">
					<h1 class="rp-post__title">{title}</h1>

					<div class="rp-post__meta">
						<span class="rp-post__metaPrimary">
							Publicado el{" "}
							{new Intl.DateTimeFormat("es-PE", {
								year: "numeric",
								month: "long",
								day: "2-digit",
							}).format(pubDate)}
						</span>

						{author ? (
							<span class="rp-post__author">· por {author}</span>
						) : null}

						{updatedDate ? (
							<span class="rp-post__updated">
								· Actualizado el{" "}
								{new Intl.DateTimeFormat("es-PE", {
									year: "numeric",
									month: "long",
									day: "2-digit",
								}).format(updatedDate)}
							</span>
						) : null}
					</div>

					{tags.length > 0 ? (
						<div class="rp-post__tags">
							{tags.map((tag) => (
								<a class="rp-post__tag" href={`/blog?tag=${encodeURIComponent(tag)}`}>
									{tag}
								</a>
							))}
						</div>
					) : null}
				</header>

				{description ? <p class="rp-post__lead">{description}</p> : null}

				{heroImage ? (
					<div class="rp-post__hero">
						<Image width={1200} height={630} src={heroImage} alt="" />
					</div>
				) : null}

				<div class="rp-post__content">
					<slot />
				</div>

				<nav class="rp-post__nav" aria-label="Navegación del post">
					<a class="rp-post__back" href="/blog">← Volver al blog</a>
				</nav>
			</article>
		</RPFrame>
	</body>
</html>