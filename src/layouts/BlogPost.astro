---
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import BaseHead from "../components/BaseHead.astro";
import BlogPostLightbox from "../components/blog/BlogPostLightbox.astro";
import RPFrame from "./RPFrame.astro";
import "../styles/blog-post.css";

type Props = {
	post: CollectionEntry<"blog">;
};

const { post } = Astro.props;

const {
	title,
	description,
	pubDate,
	updatedDate,
	heroImage,
	author,
	tags = [],
} = post.data;
---

<html lang="es">
	<head>
		<BaseHead title={title} description={description} />
	</head>

	<body>
		<RPFrame
			frameClass="rp-frameBody"
			contentClass="rp-frameContent rp-postLayout"
		>
			<article class="rp-post">
				<p class="rp-post__crumb">
					<a href="/blog">Blog</a>{tags.length > 0 ? ` / ${tags[0]}` : ""}
				</p>

				<header class="rp-post__header">
					<h1 class="rp-post__title">{title}</h1>

					<div class="rp-post__meta">
						<span class="rp-post__metaPrimary">
							Publicado el{" "}
							{new Intl.DateTimeFormat("es-PE", {
								year: "numeric",
								month: "long",
								day: "2-digit",
							}).format(pubDate)}
						</span>

						{author ? (
							<span class="rp-post__author">· por {author}</span>
						) : null}

						{updatedDate ? (
							<span class="rp-post__updated">
								· Actualizado el{" "}
								{new Intl.DateTimeFormat("es-PE", {
									year: "numeric",
									month: "long",
									day: "2-digit",
								}).format(updatedDate)}
							</span>
						) : null}
					</div>

					{tags.length > 0 ? (
						<div class="rp-post__tags">
							{tags.map((tag) => (
								<a
									class="rp-post__tag"
									href={`/blog?tag=${encodeURIComponent(tag)}`}
								>
									{tag}
								</a>
							))}
						</div>
					) : null}
				</header>

				{description ? <p class="rp-post__lead">{description}</p> : null}

				{heroImage ? (
					<div class="rp-post__hero">
						<Image
							width={1200}
							height={630}
							src={heroImage}
							alt=""
						/>
					</div>
				) : null}

				<div class="rp-post__content">
					<slot />
				</div>

				<nav class="rp-post__nav" aria-label="Navegación del post">
					<a class="rp-post__back" href="/blog">← Volver al blog</a>
				</nav>
			</article>
		</RPFrame>

		<BlogPostLightbox />
	</body>
</html>