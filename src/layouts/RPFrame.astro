---
import Header from "../components/Header.astro";
import { SITE_COPYRIGHT } from "../consts";

interface Props {
	showRail?: boolean;
	footerText?: string;
	frameClass?: string;
	contentClass?: string;
	railImageClass?: string;
}

const {
	showRail = true,
	footerText = SITE_COPYRIGHT,
	frameClass = "rp-frameBody",
	contentClass = "rp-frameContent",
	railImageClass = "rp-home__railImg",
} = Astro.props;
---

<main class="rp-main">
	<div class="rp-home-wrapper">
		<Header />

		<section class={frameClass}>
			{showRail && (
				<aside class="rp-home__rail" aria-hidden="true">
					<div class={railImageClass} role="presentation"></div>
				</aside>
			)}

			<div class={contentClass}>
				<slot />
			</div>
		</section>

		<footer class="rp-home__copyright">{footerText}</footer>
	</div>
</main>