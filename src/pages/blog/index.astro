---
import { getCollection } from "astro:content";
import BaseHead from "../../components/BaseHead.astro";
import BlogGrid from "../../components/blog/BlogGrid.astro";
import BlogPagination from "../../components/blog/BlogPagination.astro";
import BlogToolbar from "../../components/blog/BlogToolbar.astro";
import RPFrame from "../../layouts/RPFrame.astro";
import "../../styles/blog-index.css";
import {
	BLOG_PAGE_SIZE,
	SITE_DESCRIPTION,
	SITE_TITLE,
} from "../../consts";
import {
	filterPosts,
	getAllTags,
	getPublishedPosts,
	sortPosts,
} from "../../utils/blog";

const rawPosts = await getCollection("blog");
const allPosts = getPublishedPosts(rawPosts);
const allTags = getAllTags(allPosts);

const selectedTagRaw = Astro.url.searchParams.get("tag") ?? "";
const selectedSort = Astro.url.searchParams.get("sort") ?? "new";
const selectedQ = Astro.url.searchParams.get("q") ?? "";

const selectedTag =
	allTags.find((t) => t.toLowerCase() === selectedTagRaw.toLowerCase()) ?? "";

let initialPosts = filterPosts(allPosts, {
	query: selectedQ,
	tag: selectedTag,
});

initialPosts = sortPosts(
	initialPosts,
	selectedSort as "new" | "old" | "az" | "za",
);

const initialPostIds = new Set(initialPosts.map((p) => p.id));

const initialTotal = initialPosts.length;
const initialTotalPages = Math.max(1, Math.ceil(initialTotal / BLOG_PAGE_SIZE));
const initialPage = 1;
const initialStart = initialTotal > 0 ? 1 : 0;
const initialEnd = Math.min(BLOG_PAGE_SIZE, initialTotal);
---

<!doctype html>
<html lang="es">
	<head>
		<BaseHead title={`${SITE_TITLE} · Blog`} description={SITE_DESCRIPTION} />
	</head>

	<body>
		<RPFrame frameClass="rp-frameBody" contentClass="rp-blogLayout">
			<BlogToolbar
				allTags={allTags}
				selectedQ={selectedQ}
				selectedTag={selectedTag}
				selectedSort={selectedSort}
			/>

			<div class="rp-blog__results">
				<BlogGrid
					posts={allPosts}
					initialPostIds={initialPostIds}
					pageSize={BLOG_PAGE_SIZE}
				/>

				<BlogPagination
					initialTotal={initialTotal}
					initialPage={initialPage}
					initialTotalPages={initialTotalPages}
					initialStart={initialStart}
					initialEnd={initialEnd}
				/>
			</div>
		</RPFrame>

		<script define:vars={{ BLOG_PAGE_SIZE }}>
			const pageSize = BLOG_PAGE_SIZE;

			const q = document.getElementById("q");
			const tag = document.getElementById("tag");
			const sort = document.getElementById("sort");
			const apply = document.getElementById("apply");

			const grid = document.getElementById("grid");
			const cards = Array.from(grid.children);

			const count = document.getElementById("count");
			const pageInfo = document.getElementById("pageInfo");
			const pagerText = document.getElementById("pagerText");
			const prev = document.getElementById("prev");
			const next = document.getElementById("next");

			let page = 1;
			let filtered = cards;

			function normalize(s) {
				return (s || "").toLowerCase().trim();
			}

			function debounce(fn, ms) {
				let t;
				return (...args) => {
					clearTimeout(t);
					t = setTimeout(() => fn(...args), ms);
				};
			}

			function doFilter() {
				const query = normalize(q.value);
				const t = normalize(tag.value);

				filtered = cards.filter((el) => {
					const title = el.dataset.title || "";
					const desc = el.dataset.desc || "";
					const tags = el.dataset.tags || "";

					const hitQ = !query || title.includes(query) || desc.includes(query);
					const hitT = !t || tags.split("|").includes(t);

					return hitQ && hitT;
				});

				doSort();
				page = 1;
				render();
			}

			function doSort() {
				const mode = sort.value;
				filtered.sort((a, b) => {
					if (mode === "new") return Number(b.dataset.date) - Number(a.dataset.date);
					if (mode === "old") return Number(a.dataset.date) - Number(b.dataset.date);
					if (mode === "az") return (a.dataset.title || "").localeCompare(b.dataset.title || "");
					if (mode === "za") return (b.dataset.title || "").localeCompare(a.dataset.title || "");
					return 0;
				});
			}

			function render() {
				const total = filtered.length;
				const totalPages = Math.max(1, Math.ceil(total / pageSize));
				page = Math.min(page, totalPages);

				const start = (page - 1) * pageSize;
				const slice = filtered.slice(start, start + pageSize);

				cards.forEach((c) => {
					c.style.display = "none";
				});

				slice.forEach((c) => {
					c.style.display = "";
					grid.appendChild(c);
				});

				count.textContent = `Mostrando ${total} resultado${total === 1 ? "" : "s"}`;
				pageInfo.textContent = `Página ${page} / ${totalPages}`;
				pagerText.textContent = `${Math.min(start + 1, total)}–${Math.min(start + pageSize, total)} de ${total}`;

				prev.disabled = page <= 1;
				next.disabled = page >= totalPages;
			}

			apply.addEventListener("click", doFilter);
			prev.addEventListener("click", () => { page--; render(); });
			next.addEventListener("click", () => { page++; render(); });

			q.addEventListener("keydown", (e) => {
				if (e.key === "Enter") doFilter();
			});
			q.addEventListener("input", debounce(doFilter, 120));
			tag.addEventListener("change", doFilter);
			sort.addEventListener("change", () => {
				doSort();
				page = 1;
				render();
			});

			const params = new URLSearchParams(window.location.search);

			q.value = params.get("q") ?? "";
			sort.value = params.get("sort") ?? sort.value ?? "new";

			const tagParam = (params.get("tag") ?? "").toLowerCase();
			if (tagParam) {
				const opt = Array.from(tag.options).find(
					(o) => (o.value || "").toLowerCase() === tagParam
				);
				tag.value = opt ? opt.value : "";
			} else {
				tag.value = "";
			}

			doFilter();
		</script>
	</body>
</html>